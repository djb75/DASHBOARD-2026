# Template for Streamlit Community Cloud's Settings > Secrets box.
# Copy these three lines in (with your real values) there — do NOT create
# a real .streamlit/secrets.toml in this repo; it's gitignored on purpose.
# Locally, the app keeps reading these from your .env file instead.

FRED_API_KEY = "your-fred-api-key"
ALPHAVANTAGE_API_KEY = "your-alphavantage-api-key"
GROQ_API_KEY = "your-groq-api-key"
